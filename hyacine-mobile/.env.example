# NestJS backend REST API base URL.
# Android physical device on the same LAN:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api/v1
#
# Android Emulator accessing a backend running on the host machine:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api/v1
#
# Production example:
# EXPO_PUBLIC_API_URL=https://api.example.com/api/v1
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api/v1
