{
  "expo": {
    "name": "风堇音乐",
    "description": "风堇音乐是基于 TypeScript、Expo Router 和 React Native 的多音乐源客户端，支持网易云登录、推荐、歌单、搜索、播放、同步歌词、只读评论、本地收藏、听歌历史、队列与随机/循环播放、可定制播放器与设备内管理后台。",
    "slug": "hyacine-mobile",
    "scheme": "hyacine",
    "version": "Beta1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#d7f56a"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Fengjin Music to access audio files for your library."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-audio"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hyacine.music",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAppleMusicUsageDescription": "Allow Fengjin Music to access your media library."
      }
    },
    "android": {
      "package": "com.hyacine.music",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.POST_PROMOTED_NOTIFICATIONS",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#11120e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "usesCleartextTraffic": true,
      "versionCode": 9
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": true
    },
    "modules": [
      "./modules/expo-fluid-cloud",
      "./modules/expo-live-updates",
      "./modules/expo-liquid-glass"
    ]
  }
}
