{
  "expo": {
    "name": "Hyacine.music",
    "slug": "hyacine-mobile",
    "scheme": "hyacine",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-notifications", { "icon": "./assets/icon.png", "color": "#d7f56a" }],
      ["expo-media-library", { "photosPermission": "Allow Hyacine.music to access audio files for your library." }]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hyacine.music",
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSAppleMusicUsageDescription": "Allow Hyacine.music to access your media library."
      }
    },
    "android": {
      "package": "com.hyacine.music",
      "permissions": ["android.permission.POST_NOTIFICATIONS", "android.permission.READ_MEDIA_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#11120e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": { "favicon": "./assets/favicon.png" },
    "experiments": { "typedRoutes": true }
  }
}